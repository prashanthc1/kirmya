# Copy this file to .env and fill in your real values.

# --- Application ---
PORT=8080
# "production" enables Secure cookies AND fail-closed startup checks: the app
# will refuse to start without a strong JWT_SECRET / MFA_ENC_KEY and the log-only
# mailer will refuse to send (configure a real mailer).
APP_ENV=development
APP_URL=http://localhost:3000  # used in verification/reset email links

# Honour X-Forwarded-For for the client IP (audit logs). Set "true" ONLY when the
# app runs behind a trusted reverse proxy; otherwise the header is ignored.
TRUST_PROXY=false

# Require a verified email before login (recommended). Set "false" to allow login
# before verification, e.g. for local development with seed data.
EMAIL_VERIFICATION_REQUIRED=true

# Optional CSRF Origin allowlist (defense-in-depth); off unless "true". Requires
# APP_URL to match the browser origin exactly.
CSRF_VERIFY_ORIGIN=false

# --- PostgreSQL ---
# Either set DATABASE_URL directly...
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/kirmya?sslmode=disable
# ...or set the individual parts (used when DATABASE_URL is empty):
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=kirmya
POSTGRES_SSLMODE=disable

# --- Auth / JWT ---
# Secret used to sign access tokens. Required in production - generate with:
#   openssl rand -hex 32
JWT_SECRET=
JWT_ACCESS_TTL=900             # access-token lifetime in seconds (default 15m)
JWT_REFRESH_TTL=2592000        # refresh-token lifetime in seconds (default 30d)

# --- MFA (TOTP) ---
# Key to encrypt TOTP secrets at rest. Falls back to JWT_SECRET in dev; REQUIRED
# in production (the app aborts if neither this nor JWT_SECRET is set).
MFA_ENC_KEY=

# --- OAuth (optional; providers are enabled only when CLIENT_ID is set) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/oauth/google/callback

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/auth/oauth/linkedin/callback

# --- Resend (HTTP email API; PREFERRED) ---
# Used in preference to SMTP. Sends over HTTPS (443), so it works on hosts that
# block outbound SMTP (e.g. Railway below the Pro plan). Get a key at resend.com.
# Put the real key in .env (gitignored) or your host's variables — NOT here.
RESEND_API_KEY=                  # set this to enable Resend; takes priority over SMTP
RESEND_FROM=Kirmya <no-reply@kirmya.com>  # sender; the domain must be VERIFIED in Resend
                                 # (for a quick test, "Kirmya <onboarding@resend.dev>"
                                 #  works but only delivers to your Resend account email)

# --- SMTP (transactional email: verification + password reset) ---
# When SMTP_HOST is set, the real SMTP mailer is used; otherwise dev builds log
# the verification/reset link to the console (and production fails closed).
# Port 465 uses implicit TLS; any other port (587) uses STARTTLS and refuses to
# send credentials over a plaintext connection.
# NOTE: never commit real credentials here — put them in .env or host variables.
SMTP_HOST=                       # e.g. smtp.hostinger.com / smtp.titan.email / smtp.sendgrid.net
SMTP_PORT=465                    # Hostinger: 465 (implicit TLS, recommended) or 587 (STARTTLS)
SMTP_USERNAME=                   # full mailbox address; must be a REAL mailbox (e.g. no-reply@kirmya.com)
SMTP_PASSWORD=                   # the mailbox password (Hostinger Email), or API key for other providers
SMTP_FROM=no-reply@kirmya.com    # MUST equal SMTP_USERNAME on Hostinger (sender must be the authed mailbox)
SMTP_FROM_NAME=Kirmya            # From: display name
