# Production secrets for docker-compose.prod.yml.
# Copy to .env (same directory) and fill in real values:
#   cp .env.prod.example .env
# Keep .env out of git (already covered by .gitignore patterns for *.env / .env).

# --- Public domain / TLS ---
DOMAIN=kirmya.example.com         # the domain pointed at this server (A record)
ACME_EMAIL=admin@example.com      # Let's Encrypt account / expiry notices

# --- PostgreSQL ---
POSTGRES_USER=kirmya
POSTGRES_PASSWORD=                # REQUIRED — use a long random password
POSTGRES_DB=kirmya

# --- Auth (REQUIRED in production; app fails to start without these) ---
# Generate each with: openssl rand -hex 32
JWT_SECRET=
MFA_ENC_KEY=

# --- Email verification ---
# Set to false only until SMTP is configured (production fails closed otherwise).
EMAIL_VERIFICATION_REQUIRED=true

# --- SMTP (transactional email) ---
SMTP_HOST=                        # e.g. smtp.hostinger.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@kirmya.example.com
SMTP_FROM_NAME=Kirmya

# --- Optional ---
ANTHROPIC_API_KEY=                # enables AI features
GRAFANA_ADMIN_PASSWORD=           # only needed with --profile observability
